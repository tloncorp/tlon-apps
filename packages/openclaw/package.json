{
  "name": "@tloncorp/openclaw",
  "version": "0.4.3",
  "description": "OpenClaw Tlon/Urbit channel plugin",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "repository": {
    "type": "git",
    "url": "https://github.com/tloncorp/openclaw-tlon.git"
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/generate-channel-configs.mjs",
    "clean": "rm -rf dist",
    "dev": "./dev/run.sh",
    "dev:api:link": "./dev/link-local-api.sh",
    "dev:api:unlink": "./dev/unlink-local-api.sh",
    "dev:skill:link": "./dev/link-local-skill.sh",
    "dev:skill:unlink": "./dev/unlink-local-skill.sh",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint --type-aware",
    "lint:fix": "pnpm format:fix && oxlint --type-aware --fix",
    "postinstall": "node scripts/generate-version.js",
    "prebuild": "node scripts/generate-version.js",
    "test": "vitest run src/",
    "test:all": "vitest run",
    "test:integration": "bash ./test/run.sh",
    "test:integration:dev": "./test/run-dev.sh",
    "test:integration:watch": "./test/run-dev.sh --watch",
    "test:manual": "bash ./test/run-manual.sh",
    "test:security": "vitest run src/security.test.ts",
    "test:watch": "vitest src/",
    "prepare:publish": "npm run build && node scripts/prepare-publish-package.js",
    "pack:publish": "npm run prepare:publish && npm pack .publish",
    "publish:clean": "npm run prepare:publish && npm publish .publish --access public"
  },
  "dependencies": {
    "@tloncorp/api": "presence",
    "@tloncorp/tlon-skill": "^0.3.6",
    "@urbit/aura": "^3.0.0",
    "posthog-node": "^5.28.9",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "dotenv": "^17.2.4",
    "openclaw": "2026.5.7",
    "oxfmt": "0.27.0",
    "oxlint": "^1.42.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "zod": "^4.4.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.27"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "tlon",
      "label": "Tlon",
      "selectionLabel": "Tlon (Urbit)",
      "docsPath": "/channels/tlon",
      "docsLabel": "tlon",
      "blurb": "decentralized messaging on Urbit; install the plugin to enable.",
      "order": 90,
      "quickstartAllowFrom": true
    },
    "install": {
      "minHostVersion": ">=2026.4.27",
      "npmSpec": "@tloncorp/openclaw",
      "localPath": "extensions/tlon",
      "defaultChoice": "npm"
    }
  }
}
