FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y git curl jq && rm -rf /var/lib/apt/lists/*
RUN npm install -g pnpm@11.9.0

# Install OpenClaw globally (pinned to avoid dependency bugs in latest)
RUN npm install -g openclaw@2026.5.28

# Install the Brave web-search plugin at build time. openclaw@2026.5.28
# rejects tools.web.search.provider "brave" (set by entrypoint.test.sh when
# BRAVE_API_KEY is present) unless the plugin is installed. Production
# installs the same package before gateway start (tlonbot entrypoint);
# baking it here keeps container startup off the npm registry. The install
# ledger lives in ~/.openclaw/plugins/, which entrypoint.test.sh's config
# rewrite does not touch.
RUN openclaw plugins install @openclaw/brave-plugin

# Create workspace
WORKDIR /workspace

COPY entrypoint.test.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 18789

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
