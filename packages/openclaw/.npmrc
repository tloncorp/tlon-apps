# Load-bearing for the standalone container installs in dev/entrypoint*.sh,
# where this package is copied out of the workspace before `pnpm install`:
# dev/build-local-skill-override.sh hydrates the platform tlon binary by
# resolving @tloncorp/tlon-skill-<platform>-<arch> at the top level of
# node_modules, which only the hoisted layout provides. Monorepo installs read
# the workspace-root .npmrc instead (which sets the same linker).
node-linker=hoisted
