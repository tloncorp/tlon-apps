{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./scripts",
    "declaration": true,
    "types": ["node"]
  },
  "include": ["scripts/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "scripts/**/*.test.ts",
    "scripts/**/*.spec.ts",
    "scripts/tloncorp-api-mock.ts",
    "tests/**/*.ts"
  ]
}
