{
  "name": "@tloncorp/api",
  "version": "0.0.2-alpha.3",
  "type": "module",
  "files": [
    "dist",
    "src/client",
    "src/http-api",
    "src/lib",
    "src/types",
    "src/urbit"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./api": {
      "source": "./src/client/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "source": "./src/client/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./urbit": {
      "source": "./src/urbit/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./http-api": {
      "source": "./src/http-api/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/index.d.ts"
    },
    "./types/*": {
      "source": "./src/types/*.ts",
      "types": "./dist/types/*.d.ts"
    },
    "./lib/utilityTypes": {
      "types": "./src/lib/utilityTypes.d.ts",
      "default": "./src/lib/utilityTypes.d.ts"
    },
    "./package.json": "./package.json",
    "./api/*": {
      "source": "./src/client/*.ts",
      "types": "./dist/client/*.d.ts"
    },
    "./client/*": {
      "source": "./src/client/*.ts",
      "types": "./dist/client/*.d.ts"
    },
    "./lib/*": {
      "source": "./src/lib/*.ts",
      "types": "./dist/lib/*.d.ts"
    },
    "./urbit/*": {
      "source": "./src/urbit/*.ts",
      "types": "./dist/urbit/*.d.ts"
    },
    "./http-api/*": {
      "source": "./src/http-api/*.ts",
      "types": "./dist/http-api/*.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist-types && vite build && tsc -p tsconfig.build.json && cp -R dist-types/. dist/ && api-extractor run --local && rm -rf dist-types",
    "lint": "eslint src/",
    "prepare": "pnpm build",
    "tsc": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.190.0",
    "@aws-sdk/s3-request-presigner": "^3.190.0",
    "@urbit/aura": "^3.0.0",
    "@urbit/nockjs": "^1.6.0",
    "any-ascii": "^0.3.1",
    "big-integer": "^1.6.52",
    "buffer": "^5.7.1",
    "date-fns": "^2.30.0",
    "emoji-regex": "^10.4.0",
    "exponential-backoff": "^3.1.1",
    "libphonenumber-js": "^1.11.18",
    "lodash": "^4.17.21",
    "sorted-btree": "^1.8.1",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.52.11"
  }
}
