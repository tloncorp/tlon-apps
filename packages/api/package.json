{
  "name": "@tloncorp/api",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/client/index.ts",
    "./api/*": "./src/client/*.ts",
    "./client": "./src/client/index.ts",
    "./client/*": "./src/client/*.ts",
    "./lib/utilityTypes": "./src/lib/utilityTypes.d.ts",
    "./lib/*": "./src/lib/*.ts",
    "./urbit": "./src/urbit/index.ts",
    "./urbit/*": "./src/urbit/*.ts",
    "./http-api": "./src/http-api/index.ts",
    "./http-api/*": "./src/http-api/*.ts",
    "./types/*": "./src/types/*.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@tloncorp/shared": "workspace:*"
  }
}
