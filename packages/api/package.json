{
  "name": "@tloncorp/api",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./client/urbit": "./src/client/urbit.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*.ts",
    "./lib": "./src/lib/index.ts",
    "./lib/auth": "./src/lib/auth.ts",
    "./lib/content-helpers": "./src/lib/content-helpers.ts",
    "./lib/id": "./src/lib/id.ts",
    "./lib/noun": "./src/lib/noun.ts",
    "./lib/postContent": "./src/lib/postContent.ts",
    "./lib/utils": "./src/lib/utils.ts",
    "./lib/utilityTypes": "./src/lib/utilityTypes.d.ts",
    "./http-api": "./src/http-api/index.ts",
    "./http-api/*": "./src/http-api/*.ts",
    "./urbit": "./src/urbit/index.ts",
    "./urbit/*": "./src/urbit/*.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "tsc": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix --quiet",
    "lint:format": "prettier src/ --write",
    "check:boundaries": "node ./scripts/check-boundaries.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm build && node ./scripts/prepare-publish.mjs"
  },
  "dependencies": {
    "@urbit/aura": "^3.0.0",
    "@urbit/nockjs": "^1.6.0",
    "any-ascii": "^0.3.2",
    "big-integer": "^1.6.52",
    "buffer": "^6.0.3",
    "date-fns": "^3.6.0",
    "emoji-regex": "^10.3.0",
    "exponential-backoff": "^3.1.1",
    "libphonenumber-js": "^1.10.51",
    "lodash": "^4.17.21",
    "sorted-btree": "^1.8.1",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/validator": "^13.7.0",
    "typescript": "5.4.5",
    "vite": "^5.1.6",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.5.0"
  },
  "files": [
    "dist",
    "src"
  ]
}
