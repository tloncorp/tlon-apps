{
  "name": "@tloncorp/api",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "dist",
    "src/client",
    "src/http-api",
    "src/lib",
    "src/types",
    "src/urbit"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api/*": "./src/client/*.ts",
    "./client": "./src/client/index.ts",
    "./client/*": "./src/client/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./urbit": "./src/urbit/index.ts",
    "./urbit/*": "./src/urbit/*.ts",
    "./http-api": "./src/http-api/index.ts",
    "./http-api/*": "./src/http-api/*.ts",
    "./types/*": "./src/types/*.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "lint:format": "prettier ./ --write",
    "prepare": "pnpm build",
    "watch": "tsup --watch",
    "tsc": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.190.0",
    "@aws-sdk/s3-request-presigner": "^3.190.0",
    "@urbit/aura": "^3.0.0",
    "@urbit/nockjs": "^1.6.0",
    "any-ascii": "^0.3.1",
    "big-integer": "^1.6.52",
    "buffer": "^5.7.1",
    "date-fns": "^2.30.0",
    "emoji-regex": "^10.4.0",
    "exponential-backoff": "^3.1.1",
    "libphonenumber-js": "^1.11.18",
    "lodash": "^4.17.21",
    "sorted-btree": "^1.8.1",
    "validator": "^13.7.0"
  }
}
