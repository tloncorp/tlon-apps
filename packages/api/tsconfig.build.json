{
  "extends": "./tsconfig.json",
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./src/test/**/*",
    "./src/__tests__/**/*"
  ],
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "incremental": false,
    "outDir": "./dist-types",
    "rootDir": "./src"
  }
}
