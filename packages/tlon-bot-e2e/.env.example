# Optional local settings for the shared bot E2E harness.
#
# Shell environment variables take precedence over values in this file.
# Keep real credentials in packages/tlon-bot-e2e/.env, which is gitignored.

# Driver selection
# TLON_BOT_E2E_DRIVER=hermes
# TLON_BOT_E2E_DRIVER=openclaw

# Runner selection. Shell overrides still take precedence.
# TLON_BOT_E2E_SUITE=common
# TLON_BOT_E2E_SUITE=package
# TLON_BOT_E2E_SUITE=all
# TLON_BOT_E2E_SCENARIO_PARTITIONS=baseline
# TLON_BOT_E2E_SCENARIO_PARTITIONS=all

# Runtime identity and lifecycle
# TLON_BOT_E2E_REPO_ROOT=../..
# TLON_BOT_E2E_RUN_ID=local-run
# TLON_BOT_E2E_KEEP_STACK=1
# DUMP_LOGS=1

# Optional fixed host ports. Leave unset for automatic allocation.
# FAKE_MODEL_PORT=4000
# ZOD_PORT=41080
# TEN_PORT=41081
# MUG_PORT=41082
# OPENCLAW_GATEWAY_PORT=41083

# OpenClaw local runtime inputs
# FAKE_SHIP_CACHE_DIR=/tmp/tlon-bot-e2e-fake-ship-cache
# TLONBOT_DIR=/path/to/tlonbot
# TLONBOT_TOKEN=
# BRAVE_API_KEY=

# Loop-protection scenario overrides. Defaults are driver-managed.
# TLON_KNOWN_BOT_USERS=~mug
# TLON_MAX_CONSECUTIVE_BOT_RESPONSES=2

# Media/blob scenario storage. Required for tests that hit real object storage.
# TEST_STORAGE_ENDPOINT=
# TEST_STORAGE_BUCKET=
# TEST_STORAGE_ACCESS_KEY=
# TEST_STORAGE_SECRET_KEY=
# TEST_STORAGE_REGION=

# Debug and live trace controls
# TEST_LIVE_TOOL_TRACE=1
# TEST_LIVE_TOOL_TRACE_CONTENTS=1
# CI_LIVE_TOOL_TRACE=1
# CI_LIVE_TOOL_TRACE_CONTENTS=1
# VERBOSE=1
# HERMES_PLUGINS_DEBUG=1
