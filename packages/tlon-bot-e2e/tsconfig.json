{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "incremental": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.mjs",
    "src/**/*.d.mts",
    "scripts/**/*.mjs",
    "vitest.config.ts",
    "vitest.e2e.config.ts"
  ]
}
