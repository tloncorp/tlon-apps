{
  "name": "tlon-mobile",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"tailwindcss --input input.css --output tailwind.css --no-autoprefixer --watch\" \"tailwind-rn --watch\"",
    "android": "expo run:android --variant=productionDebug",
    "android:preview": "cross-env APP_VARIANT=preview expo run:android --variant=previewDebug",
    "android:release": "rm -rf android/app/build/generated/assets/createBundleProductionReleaseJsAndAssets && pnpm exec expo run:android --variant=productionRelease",
    "android:release:preview": "cross-env APP_VARIANT=preview pnpm exec expo run:android --variant=previewRelease",
    "android:update-lockfile": "cd android && ./gradlew app:dependencies --write-locks",
    "bundler": "expo start",
    "clearcache": "expo start -c",
    "ios": "expo run:ios",
    "ios:release:preview": "cross-env APP_VARIANT=preview pnpm exec expo run:ios --scheme=Landscape-preview --configuration Release",
    "ios:release": "pnpm exec expo run:ios --configuration Release",
    "ios:preview": "cross-env APP_VARIANT=preview expo run:ios --scheme=Landscape-preview",
    "generate": "pnpm generate:tailwind && pnpm run generate:ios",
    "generate:ios": "expo export:embed --platform ios --bundle-output ./ios/main.jsbundle --assets-dest ./ios",
    "generate:tailwind": "tailwindcss --input input.css --output tailwind.css --no-autoprefixer && tailwind-rn",
    "lint": "eslint ./src",
    "lint:fix": "pnpm lint:fix:js",
    "lint:fix:js": "eslint --fix --quiet ./src",
    "lint:format": "pnpm lint:format:js && pnpm lint:format:swift",
    "lint:format:js": "prettier --write .",
    "lint:format:swift": "swiftformat **/*.swift --exclude ./ios/Pods, ./node_modules",
    "lint:staged": "lint-staged",
    "test-ui": "jest",
    "tsc": "tsc --noEmit",
    "build": "pnpm generate",
    "cosmos": "cosmos-native",
    "eas-build-post-install": "pnpm -w run build:mobile-release",
    "test-android-resume": "./scripts/test-background-resume.sh"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,html}": [
      "pnpm lint:fix:js",
      "pnpm lint:format:js"
    ],
    "*.swift": [
      "pnpm lint:format:swift"
    ]
  },
